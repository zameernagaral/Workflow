# Environment Configuration
# Copy this file to .env and fill in your actual values.

# ── Google Meet Bot Setup ────────────────────────────────────────────────────
# The caption bot uses a persistent Chrome profile at ./meet-bot-profile/
# On first run, the browser will open so you can log in with your Google account.
# After that, the session is saved and the bot joins meetings automatically.
# No Google Workspace subscription required.
# ─────────────────────────────────────────────────────────────────────────────

# Google Drive (Service Account or OAuth credentials JSON path)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Jira Cloud API
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_DOMAIN=your-domain.atlassian.net
JIRA_PROJECT_KEY=TASK

# Notion API
NOTION_API_KEY=secret_your_notion_internal_integration_token
NOTION_DATABASE_ID=your_database_id

# Slack API
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C01234567

# App Settings
POLL_INTERVAL_MS=60000
CONFIDENCE_THRESHOLD=80
